<% layout("./listing/layouts/boilerplate") %>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-calendar-check me-2 text-primary"></i>Booking Details</h2>
        <div>
            <a href="/admin/bookings" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Bookings
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Booking Info -->
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Booking Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Booking ID:</strong>
                            <p><code><%= booking._id %></code></p>
                        </div>
                        <div class="col-md-6">
                            <strong>Booking Date:</strong>
                            <p><%= new Date(booking.createdAt).toLocaleString() %></p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Check-in:</strong>
                            <p><%= new Date(booking.checkIn).toDateString() %></p>
                        </div>
                        <div class="col-md-6">
                            <strong>Check-out:</strong>
                            <p><%= new Date(booking.checkOut).toDateString() %></p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Duration:</strong>
                            <p><%= booking.totalNights %> nights</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Guests:</strong>
                            <p><%= booking.guests.adults %> Adults, <%= booking.guests.children %> Children</p>
                        </div>
                    </div>

                    <hr>

                    <h6 class="mb-3">Price Breakdown</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <p>Price per night: <strong>₹<%= booking.pricePerNight %></strong></p>
                            <p>Total nights: <strong><%= booking.totalNights %></strong></p>
                        </div>
                        <div class="col-md-6">
                            <p class="h5 text-success">Total Amount: <strong>₹<%= booking.totalPrice.toLocaleString() %></strong></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Guest Info -->
            <div class="card shadow mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Guest Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>Full Name:</strong>
                            <p><%= booking.guestInfo.fullName %></p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <strong>Email:</strong>
                            <p><%= booking.guestInfo.email %></p>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>Phone:</strong>
                            <p><%= booking.guestInfo.phone || 'Not provided' %></p>
                        </div>
                    </div>
                    <% if (booking.guestInfo.specialRequests) { %>
                        <div class="mt-3">
                            <strong>Special Requests:</strong>
                            <div class="alert alert-light border mt-2">
                                <%= booking.guestInfo.specialRequests %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Listing Info -->
            <% if (booking.listing) { %>
                <div class="card shadow mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-home me-2"></i>Listing Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex">
                            <% if(booking.listing.images && booking.listing.images.length > 0) { %>
                                <img src="<%= booking.listing.images[0].url %>" alt="<%= booking.listing.title %>" class="rounded" style="width: 150px; height: 100px; object-fit: cover;">
                            <% } %>
                            <div class="ms-3">
                                <h5><%= booking.listing.title %></h5>
                                <p class="text-muted mb-1"><i class="fas fa-map-marker-alt me-1"></i><%= booking.listing.location %>, <%= booking.listing.country %></p>
                                <p class="mb-0">Category: <span class="badge bg-secondary"><%= booking.listing.category %></span></p>
                                <a href="/listings/<%= booking.listing._id %>" target="_blank" class="btn btn-sm btn-outline-primary mt-2">
                                    <i class="fas fa-external-link-alt me-1"></i>View Listing
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Status Management -->
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Manage Booking</h5>
                </div>
                <div class="card-body">
                    <!-- Current Status -->
                    <div class="mb-4">
                        <strong>Current Status:</strong><br>
                        <span class="badge 
                            <%= booking.status === 'confirmed' ? 'bg-success' : '' %>
                            <%= booking.status === 'pending' ? 'bg-warning' : '' %>
                            <%= booking.status === 'cancelled' ? 'bg-danger' : '' %>
                            <%= booking.status === 'completed' ? 'bg-info' : '' %>"
                            style="font-size: 1rem; padding: 0.5rem 1rem;">
                            <%= booking.status %>
                        </span>
                    </div>

                    <!-- Update Status Form -->
                    <form action="/admin/bookings/<%= booking._id %>/status" method="POST" class="mb-4">
                        <label class="form-label fw-bold">Update Status</label>
                        <select name="status" class="form-select mb-2">
                            <option value="pending" <%= booking.status === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value="confirmed" <%= booking.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                            <option value="completed" <%= booking.status === 'completed' ? 'selected' : '' %>>Completed</option>
                            <option value="cancelled" <%= booking.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-sync me-1"></i>Update Status
                        </button>
                    </form>

                    <hr>

                    <!-- Payment Info -->
                    <div class="mb-4">
                        <strong>Payment Method:</strong><br>
                        <span class="badge bg-info text-dark" style="font-size: 0.9rem; padding: 0.4rem 0.8rem;">
                            <%= booking.payment.method ? booking.payment.method.toUpperCase() : 'Not Selected' %>
                        </span>
                        <% if (booking.payment.upiId) { %>
                            <br><small class="text-muted">UPI ID: <%= booking.payment.upiId %></small>
                        <% } %>
                        <% if (booking.payment.notes) { %>
                            <br><small class="text-muted">Notes: <%= booking.payment.notes %></small>
                        <% } %>
                    </div>

                    <hr>

                    <!-- Payment Status -->
                    <div class="mb-4">
                        <strong>Payment Status:</strong><br>
                        <span class="badge 
                            <%= booking.payment.status === 'paid' ? 'bg-success' : '' %>
                            <%= booking.payment.status === 'pending' ? 'bg-warning' : '' %>
                            <%= booking.payment.status === 'failed' ? 'bg-danger' : '' %>
                            <%= booking.payment.status === 'refunded' ? 'bg-secondary' : '' %>"
                            style="font-size: 1rem; padding: 0.5rem 1rem;">
                            <%= booking.payment.status %>
                        </span>
                        <% if (booking.payment.paidAt) { %>
                            <br><small class="text-muted">Paid on: <%= new Date(booking.payment.paidAt).toLocaleString() %></small>
                        <% } %>
                    </div>

                    <!-- Update Payment Form -->
                    <form action="/admin/bookings/<%= booking._id %>/payment" method="POST" class="mb-4">
                        <label class="form-label fw-bold">Update Payment</label>
                        <select name="paymentStatus" class="form-select mb-2">
                            <option value="pending" <%= booking.payment.status === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value="paid" <%= booking.payment.status === 'paid' ? 'selected' : '' %>>Paid</option>
                            <option value="failed" <%= booking.payment.status === 'failed' ? 'selected' : '' %>>Failed</option>
                            <option value="refunded" <%= booking.payment.status === 'refunded' ? 'selected' : '' %>>Refunded</option>
                        </select>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-credit-card me-1"></i>Update Payment
                        </button>
                    </form>

                    <hr>

                    <!-- Delete Booking -->
                    <form action="/admin/bookings/<%= booking._id %>?_method=DELETE" method="POST">
                        <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Are you sure you want to delete this booking? This action cannot be undone.')">
                            <i class="fas fa-trash me-1"></i>Delete Booking
                        </button>
                    </form>
                </div>
            </div>

            <!-- User Info -->
            <% if (booking.user) { %>
                <div class="card shadow">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-user-circle me-2"></i>User Account</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Username:</strong> <%= booking.user.username %></p>
                        <p><strong>Email:</strong> <%= booking.user.email %></p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>
